#!/usr/bin/env sh

# Try to make this script shell agnostic, though the rest of the repo scripts
# may not be.

REPO_URL="https://github.com/ericelsken/.dotfiles"
REPO_DIR="${HOME}/.dotfiles"

if [ -z "${HOME}" ]; then
	echo >&2 "HOME is not set. Quitting."
	exit 2
fi

if ! command -v git > /dev/null; then
	echo >&2 "Cannot find git. Install then re-run this script."
	exit 1
fi

if [ -d "${REPO_DIR}/.git" ]; then
	echo >&2 "Installation destination ${REPO_DIR} is already a git repository. Not doing anything. Bye."
	exit 0
fi

if [ -e "${REPO_DIR}" ] && [ ! -d "${REPO_DIR}/.git" ]; then
	echo >&2 "Installation destination ${REPO_DIR} exists but is not a git repository."
	exit 1
fi

git clone "${REPO_URL}" "${REPO_DIR}"

