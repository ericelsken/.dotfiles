#!/usr/bin/env bash

set -euo pipefail

REPO_DIR="${HOME}/.dotfiles"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo >&2 "Missing required command: $1"
    exit 2
  fi
}

need stow

if [ ! -d "${REPO_DIR}" ]; then
  echo >&2 "Dotfiles repo not found at ${REPO_DIR}. Clone it first (e.g., e2 dotfiles-install)."
  exit 1
fi

# Restow XDG packages into their matching target directories. Stow strips the
# package name, so targeting $HOME would link .config contents directly there.
echo "Stowing packages from ${REPO_DIR}..."
mkdir -p "${HOME}/.config" "${HOME}/.local"
stow -v -d "${REPO_DIR}" -t "${HOME}/.config" -R .config
stow -v -d "${REPO_DIR}" -t "${HOME}/.local" -R .local

# Link top-level files not covered by stow packages
for f in .bashrc .bash_profile .gitconfig; do
  if [ -e "${REPO_DIR}/${f}" ]; then
    ln -snf "${REPO_DIR}/${f}" "${HOME}/${f}"
    echo "Linked ${HOME}/${f} -> ${REPO_DIR}/${f}"
  fi
done

echo "Done."
